# Core model APIs
OPENAI_API_KEY=
OPENAI_PLANNER_MODEL=gpt-5.4-mini
OPENAI_ASSET_MODEL=gpt-5.4-mini
OPENAI_PRODUCT_USE_MODEL=gpt-5.4-mini
OPENAI_STARTER_IMAGE_MODEL=gpt-image-2
OPENAI_STARTER_IMAGE_QUALITY=medium

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# Optional. If absent, OpenAI is used for copy/prompt planning when OPENAI_API_KEY is present.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Video engine
# atlas_reference_to_video or fal_kling_v3_pro_i2v
VIDEO_ENGINE=fal_kling_v3_pro_i2v
FAL_KEY=
FAL_API_KEY=

# Atlas Cloud fallback
ATLASCLOUD_API_KEY=
ATLASCLOUD_BASE_URL=https://api.atlascloud.ai/api/v1
ATLASCLOUD_VIDEO_MODEL=bytedance/seedance-2.0-fast/text-to-video
ATLASCLOUD_REFERENCE_VIDEO_MODEL=kwaivgi/kling-video-o3-pro/reference-to-video
SEEDANCE_RESOLUTION=480p
SEEDANCE_RATIO=9:16

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_flash_v2_5

# Creatomate
CREATOMATE_API_KEY=
CREATOMATE_BASE_URL=https://api.creatomate.com/v2
CREATOMATE_RENDER_MODE=renderscript
CREATOMATE_TEMPLATE_ID=caf995e8-f827-462c-ab1e-dcce3be5ebea

# Modification keys in your Creatomate template. Change to match your template.
CREATOMATE_VIDEO_LAYER=Video.source
CREATOMATE_AUDIO_LAYER=Audio.source
CREATOMATE_HEADLINE_LAYER=Text-1.text
CREATOMATE_CAPTION_LAYER=Text-2.text
CREATOMATE_PRODUCT_LAYER=Product.text

# Cloudflare R2 for public media URLs used by Creatomate
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
R2_PREFIX=ugcday-mvp
